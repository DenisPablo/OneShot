# API Keys para servicios OSINT
# Copia este archivo a .env y completa las keys que necesites

# Censys - Búsqueda de hosts y servicios en Internet (plan gratuito disponible)
# Requiere Personal Access Token (un solo token)
# Obtén tu token en: https://accounts.censys.io/settings/personal-access-tokens
CENSYS_API_TOKEN=

# EmailRep - Análisis de reputación de emails (opcional)
# Obtén tu API key en: https://emailrep.io/
EMAILREP_API_KEY=

# OpenRouter - Análisis con IA (requerido para --analyze)
# Obtén tu API key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=
